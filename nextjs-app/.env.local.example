# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://zjhmcyvrziwwkdcylktj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL — http://localhost:3000 locally, https://www.agenzia.uk in prod
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — existing credentials
# GOOGLE_CLIENT_ID is used server-side; NEXT_PUBLIC_ variant is the fallback
GOOGLE_CLIENT_ID=553514518104-xxxxx.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=553514518104-xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Google token encryption — 64-char hex (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=your-64-char-hex-key

# Stripe — from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
