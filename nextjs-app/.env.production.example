# =============================================================================
# Radiance ERP — Production Environment Variables
# =============================================================================
# Copy this file and fill in real values before deploying to Vercel.
# Set these via: Vercel Dashboard → Project → Settings → Environment Variables
# DO NOT commit a file containing real secret values.
# =============================================================================

# Supabase — Project URL (public, safe to expose to client)
# Find at: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://zjhmcyvrziwwkdcylktj.supabase.co

# Supabase — Anonymous key (public, safe to expose to client)
# Find at: Supabase Dashboard → Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Service role key (SECRET — server-only, NEVER expose to client)
# Used in: server-side Route Handlers (e.g. /api/auth/google, /api/auth/logout)
# Find at: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google OAuth — Client ID (public, safe to expose to client)
# Find at: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REDACTED_GOOGLE_CLIENT_ID

# Google OAuth — Client Secret (SECRET — server-only)
# Find at: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Next.js base URL — used for OAuth redirect_uri construction
# Set to your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app

# Stripe — Secret key (SECRET — server-only)
# Find at: Stripe Dashboard → Developers → API keys → Secret key
# Use sk_live_... for production, sk_test_... for staging
STRIPE_SECRET_KEY=sk_live_...

# Stripe — Webhook signing secret (SECRET — server-only)
# Find at: Stripe Dashboard → Developers → Webhooks → signing secret
# Required for /api/stripe/webhook to verify event authenticity
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Publishable key (public, safe to expose to client)
# Find at: Stripe Dashboard → Developers → API keys → Publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
